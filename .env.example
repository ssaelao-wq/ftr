# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ftr_db
DB_PORT=3306

# Server Configuration
PORT=3000
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium # Optional: Override Chrome path

# Line API Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here
LIFF_ID_PROFILE_FORM=your_liff_id_profile_form_here
LIFF_ID_REQUEST_FORM=your_liff_id_request_form_here

# Email Configuration — Gmail OAuth2 (Option A from setup_sending_via_gmail.md)
EMAIL_USER=admin-ucs@uniconcontainer.com
OAUTH_CLIENT_ID=your_gcp_client_id_here.apps.googleusercontent.com
OAUTH_CLIENT_SECRET=GOCSPX-your_gcp_client_secret_here
OAUTH_REFRESH_TOKEN=1//your_persistent_refresh_token_from_playground

# Admin Authentication
SESSION_SECRET=your_session_secret_key_here
EXPORT_LOGS_LIMIT=200

# Cleanup Configuration (retention days)
PDF_MAX_DAYS=180
INVOICE_MAX_DAYS=180
LOG_MAX_DAYS=60
TEMP_FILES_MAX_DAYS=1
